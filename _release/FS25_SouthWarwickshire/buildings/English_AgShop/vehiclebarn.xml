<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="simplePlaceable" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>vehicle barn</name>
        <functions>
            <function>$l10n_function_garage</function>
        </functions>
        <image>store/store_vehiclebarn.png</image>
        <price>90000</price>
        <dailyUpkeep>20</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>LIZARD</brand>
        <species>placeable</species>
        <category>sheds</category>
        <brush>
            <type>placeable</type>
            <category>buildings</category>
            <tab>sheds</tab>
        </brush>
        <vertexBufferMemoryUsage>837376</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>101888</indexBufferMemoryUsage>
        <textureMemoryUsage>4784128</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>vehiclebarn.i3d</filename>
    </base>

    <placeableType>placeable</placeableType>
	
	<placement useRandomYRotation="false" useManualYRotation="true" >
        <testAreas>
            <testArea startNode="testArea1Start" endNode="testArea1End" />
        </testAreas>
    </placement>

    <clearAreas>
        <clearArea startNode="clearArea1Start" widthNode="clearArea1Width" heightNode="clearArea1Height"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="5" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="levelArea1Start" widthNode="levelArea1Width" heightNode="levelArea1Height" groundType="asphalt"/>
        </levelAreas>
    </leveling>

    <indoorAreas>
        <indoorArea startNode="indoorArea1Start" widthNode="indoorArea1Width" heightNode="indoorArea1Height" />
    </indoorAreas>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateArea1Start" endNode="tipOcclusionUpdateArea1End" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateArea1Start" endNode="tipOcclusionUpdateArea1End" />
        </updateAreas>
    </ai>

    <dynamicallyLoadedParts>
		<dynamicallyLoadedPart filename="objects.i3d"  node="0" linkNode="propsLinkNode" />
		<dynamicallyLoadedPart node="0" linkNode="powerSwitch01"   filename="$data/shared/assets/lights/terraLed/switch.i3d" />
	</dynamicallyLoadedParts>
	
    <lights>
        <sharedLight filename="$data/shared/assets/lights/terraLed/fluorescentTube50W.xml" linkNode="lightNode01" groupIndex="1">
            <rotationNode name="rotationNode01" rotation="0 0 -15" />
        </sharedLight>
        <sharedLight filename="$data/shared/assets/lights/terraLed/fluorescentTube50W.xml" linkNode="lightNode02" groupIndex="1">
            <rotationNode name="rotationNode01" rotation="0 0 15" />
        </sharedLight>
        <sharedLight filename="$data/shared/assets/lights/terraLed/fluorescentTube50W.xml" linkNode="lightNode03" groupIndex="1">
            <rotationNode name="rotationNode01" rotation="0 0 -15" />
        </sharedLight>
        <sharedLight filename="$data/shared/assets/lights/terraLed/fluorescentTube50W.xml" linkNode="lightNode04" groupIndex="1">
            <rotationNode name="rotationNode01" rotation="0 0 15" />
        </sharedLight>

        <realLights>
            <low>
                <light node="realLightsLow" groupIndex="1"/>
            </low>
            <high>
                <light node="realLightsHigh" groupIndex="1"/>
            </high>
        </realLights>

        <group name="$l10n_action_placeableLightShed" triggerNode="lightTrigger">
            <sounds>
                <toggle template="lizardFloodLight" innerRadius="50" outerRadius="100" volumeScale="0.2"/>
            </sounds>
        </group>
    </lights>
	
	<animatedObjects>
        <animatedObject saveId="rollingDoor1" >
            <animation duration="5">
                <part node="rollingDoor1">
                    <keyFrame time="0.0" translation="0 0 0"/>
                    <keyFrame time="1.0" translation="0 4.35 0"/>
                </part>
                <part node="rollingDoor1ColPartBottom">
                    <keyFrame time="0.0" translation="0 0 0"/>
                    <keyFrame time="1.0" translation="0 4.35 0"/>
                </part>
                <part node="rollingDoor1ColPartTop">
                    <keyFrame time="0.0" translation="0 0 0"/>
                    <keyFrame time="0.5" translation="0 0 0"/>
                    <keyFrame time="1.0" translation="0 2.114 0"/>
                </part>
                <shader node="rollingDoor1" parameterName="visibilityCutThreshold">
                    <keyFrame time="0.0" values="0 - - - " />
                    <keyFrame time="1.0" values="0.94 - - -" />
                </shader>
            </animation>
            <controls triggerNode="rollingDoor1Trigger" posAction="ACTIVATE_HANDTOOL" posText="action_openGate" negText="action_closeGate" />
            <sounds>
                <moving linkNode="rollingDoor1Base" template="rollingGarageDoor" />
                <posEnd linkNode="rollingDoor1Base" template="slidingGateMetalOpen" />
                <negEnd linkNode="rollingDoor1Base" template="slidingGateMetalClose" />
            </sounds>
        </animatedObject>
    
	    <animatedObject saveId="rollingDoor2" >
            <animation duration="5">
                <part node="rollingDoor2">
                    <keyFrame time="0.0" translation="0 0 0"/>
                    <keyFrame time="1.0" translation="0 4.35 0"/>
                </part>
                <part node="rollingDoor2ColPartBottom">
                    <keyFrame time="0.0" translation="0 0 0"/>
                    <keyFrame time="1.0" translation="0 4.35 0"/>
                </part>
                <part node="rollingDoor2ColPartTop">
                    <keyFrame time="0.0" translation="0 0 0"/>
                    <keyFrame time="0.5" translation="0 0 0"/>
                    <keyFrame time="1.0" translation="0 2.114 0"/>
                </part>
                <shader node="rollingDoor2" parameterName="visibilityCutThreshold">
                    <keyFrame time="0.0" values="0 - - - " />
                    <keyFrame time="1.0" values="0.94 - - -" />
                </shader>
            </animation>
            <controls triggerNode="rollingDoor2Trigger" posAction="ACTIVATE_HANDTOOL" posText="action_openGate" negText="action_closeGate" />
            <sounds>
                <moving linkNode="rollingDoor2Base" template="rollingGarageDoor" />
                <posEnd linkNode="rollingDoor2Base" template="slidingGateMetalOpen" />
                <negEnd linkNode="rollingDoor2Base" template="slidingGateMetalClose" />
            </sounds>
        </animatedObject>
	</animatedObjects>	
	
	
	<i3dMappings>
		<i3dMapping id="clearArea1Start" node="0>12|0" />
        <i3dMapping id="clearArea1Width" node="0>12|0|0" />
        <i3dMapping id="clearArea1Height" node="0>12|0|1" />
        <i3dMapping id="levelArea1Start" node="0>13|0" />
        <i3dMapping id="levelArea1Width" node="0>13|0|0" />
        <i3dMapping id="levelArea1Height" node="0>13|0|1" />
        <i3dMapping id="indoorArea1Start" node="0>14|0" />
        <i3dMapping id="indoorArea1Width" node="0>14|0|0" />
        <i3dMapping id="indoorArea1Height" node="0>14|0|1" />
        <i3dMapping id="testArea1Start" node="0>15|0" />
        <i3dMapping id="testArea1End" node="0>15|0|0" />
        <i3dMapping id="tipOcclusionUpdateArea1Start" node="0>16|0" />
        <i3dMapping id="tipOcclusionUpdateArea1End" node="0>16|0|0" />
        
		<i3dMapping id="propsLinkNode" node="0>18" />
		
		<i3dMapping id="rollingDoor1Base" node="0>17|0" />
        <i3dMapping id="rollingDoor1" node="0>17|0|0" />
        <i3dMapping id="rollingDoor1ColPartBottom" node="0>17|0|1" />
        <i3dMapping id="rollingDoor1ColPartTop" node="0>17|0|2" />
        <i3dMapping id="rollingDoor1Trigger" node="0>17|0|3" />
	
		<i3dMapping id="rollingDoor2Base" node="0>17|1" />
        <i3dMapping id="rollingDoor2" node="0>17|1|0" />
        <i3dMapping id="rollingDoor2ColPartBottom" node="0>17|1|1" />
        <i3dMapping id="rollingDoor2ColPartTop" node="0>17|1|2" />
        <i3dMapping id="rollingDoor2Trigger" node="0>17|1|3" />
	
            <i3dMapping id="lightNode01" node="0>19|1" />
		<i3dMapping id="lightNode02" node="0>19|2" />
		<i3dMapping id="lightNode03" node="0>19|3" />
		<i3dMapping id="lightNode04" node="0>19|4" />
		<i3dMapping id="powerSwitch01" node="0>19|6" />
		
		<i3dMapping id="realLightsLow" node="0>19|5|0" />
		<i3dMapping id="realLightsHigh" node="0>19|5|1" />
		
		<i3dMapping id="lightTrigger" node="0>19|0" />
	</i3dMappings>
</placeable>