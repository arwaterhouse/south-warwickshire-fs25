<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<modDesc descVersion="80">
    <author>Lancyboi</author>
    <version>1.1.0.0</version>
    <title>
        <en>English Barn Pack</en>
		<de>Große Scheune</de>
    </title>
    <description>
        <en>
<![CDATA[
 
 - Changelog 1.1.0.0 Roof Meshes re done & snow mask fixed.
 
 -  1 x Large grain barn with personal workshop for repairs Cost £140500
 -  5 Door 
 -  Daily Up keep £30 
 
 -  1 x Medium size vehicle barn £90000
 -  2 Door 
 -  Daily Up keep £20
 
 - 1 x Medium size standard size barn ideal for all lawn mowing contract vehicles and agricutural vehicles £45000 
 - 1 door
 - Daily Up keep £20
  ]]>
        </en>
        <de>
<![CDATA[
 
 - Changelog 1.1.0.0 Dachnetze überarbeitet und Schneemaske behoben.
 
 - 1 x Große Getreidescheune mit persönlicher Werkstatt für Reparaturen Kosten €140500
 - 5 Tür
 - Täglicher Unterhalt €30
 
 - 1 x Scheune für Fahrzeuge mittlerer Größe €90000
 - 2 Tür
 - Tägliche Aufwärtsbewahrung €20
 
 - 1 x Stall mittlerer Größe,ideal für alle Vertragsfahrzeuge zum Rasenmähen und landwirtschaftliche Fahrzeuge €45000
 - 1 Tür
 - Tägliche Aufwärtsbewahrung €20
]]>
        </de>
        <fr>
<![CDATA[
 
 - Changelog 1.1.0.0 Les maillages de toit sont terminés et le masque de neige est réparé.
 
 - 1 x grande grange à grains avec atelier personnel pour les réparations Coût €140500
 - 5 portes
 - Daily Up garder €30 
 
 - 1 x grange pour véhicules de taille moyenne €90000
 - 2 portes
 - Daily Up garder €20
 
 - 1 x grange de taille standard de taille moyenne idéale pour tous les véhicules contractuels de tonte de pelouse et les véhicules agricoles €45000 
 - 1 porte
 - Daily Up garder €20
]]>
        </fr>
    </description>
    <iconFilename>store/English_Barn_Pack_icon.dds</iconFilename>
    <multiplayer supported="true" />
	    
    <storeItems>
        <storeItem xmlFilename="largebarn.xml"/> 
        <storeItem xmlFilename="vehiclebarn.xml"/>
	    <storeItem xmlFilename="lawn_barn.xml"/>
	
	</storeItems>
	
