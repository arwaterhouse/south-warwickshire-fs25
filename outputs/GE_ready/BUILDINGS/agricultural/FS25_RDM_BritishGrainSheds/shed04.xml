<?xml version='1.0' encoding='utf-8'?>
<placeable xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" type="simplePlaceable" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
  <storeData>
    <name>$l10n_RDM_Shed4</name>
    <functions>
      <function>$l10n_function_garage</function>
    </functions>
    <image>store_BlueGrainBarn4.dds</image>
    <price>80000</price>
    <dailyUpkeep>25</dailyUpkeep>
    <lifetime>1000</lifetime>
    <rotation>0</rotation>
    <brand>NONE</brand>
    <canBeSold>true</canBeSold>
    <showInStore>true</showInStore>
    <species>placeable</species>
    <category>sheds</category>
    <brush>
      <type>placeable</type>
      <category>buildings</category>
      <tab>sheds</tab>
    </brush>
        <vertexBufferMemoryUsage>423936</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>65536</indexBufferMemoryUsage>
        <textureMemoryUsage>4128768</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
  </storeData>
  <base>
    <filename>shed04.i3d</filename>
	<canBeRenamed>true</canBeRenamed>
	<boughtWithFarmland>true</boughtWithFarmland>
  </base>
  <placeableType>placeable</placeableType>
  <placement useRandomYRotation="false" useManualYRotation="true">
    <testAreas>
      <testArea startNode="testArea1Start" endNode="testArea1End" />
    </testAreas>
    <sounds>
      <place template="medImp" />
    </sounds>
  </placement>
  <clearAreas>
    <clearArea startNode="clearArea1Start" widthNode="clearArea1Width" heightNode="clearArea1Height" />
  </clearAreas>
  <leveling requireLeveling="true" maxSmoothDistance="5" maxSlope="75" maxEdgeAngle="30">
    <levelAreas>
      <levelArea startNode="levelArea1Start" widthNode="levelArea1Width" heightNode="levelArea1Height" groundType="asphalt" />
    </levelAreas>
  </leveling>
  <indoorAreas>
    <indoorArea startNode="indoorArea1Start" widthNode="indoorArea1Width" heightNode="indoorArea1Height" />
  </indoorAreas>
  <tipOcclusionUpdateAreas>
    <tipOcclusionUpdateArea startNode="tipOcclusionUpdateArea1Start" endNode="tipOcclusionUpdateArea1End" />
  </tipOcclusionUpdateAreas>
  <ai>
    <updateAreas>
      <updateArea startNode="tipOcclusionUpdateArea1Start" endNode="tipOcclusionUpdateArea1End" />
    </updateAreas>
  </ai>
  <animatedObjects>
    <animatedObject saveId="Door">
      <animation duration="12">
        <part node="LeftDoor">
          <keyFrame time="0.0" translation="0 0 0" scale="1 1 1" />
          <keyFrame time="1" translation="-5.5 0 0" scale="1 1 1" />
          <!-- <keyFrame time="0.084" translation="0 0.516 0" scale="1 0 1" /> -->
        </part>
        <part node="RightDoor">
          <keyFrame time="0.0" translation="0 0 0" scale="1 1 1" />
          <keyFrame time="1" translation="5.5 0 0" scale="1 1 1" />
          <!-- <keyFrame time="0.167" translation="0 0.989 0" scale="1 0 1" /> -->
        </part>
      </animation>
      <controls triggerNode="DoorTrigger" posAction="ACTIVATE_HANDTOOL" posText="action_openDoor" negText="action_closeDoor" />
      <sounds>
        <moving linkNode="LeftDoor" template="rollingGarageDoor" />
        <posEnd linkNode="LeftDoor" template="slidingGateMetalOpen" />
        <negEnd linkNode="LeftDoor" template="slidingGateMetalClose" />
      </sounds>
    </animatedObject>
  </animatedObjects>
  <dynamicallyLoadedParts>
    <dynamicallyLoadedPart node="0" linkNode="lightSwitch" filename="$data/shared/assets/lights/terraLed/switch.i3d" />
  </dynamicallyLoadedParts>
  <lights>
    <group name="$l10n_action_placeableLightShed" triggerNode="lightTrigger">
      <sounds>
        <toggle template="lizardFloodLight" innerRadius="50" outerRadius="100" volumeScale="0.2" />
      </sounds>
    </group>
    <sharedLight filename="$data/shared/assets/lights/terraLed/fluorescentTube50W.xml" linkNode="tube1" groupIndex="1" color="1 1 1" />
    <sharedLight filename="$data/shared/assets/lights/terraLed/fluorescentTube50W.xml" linkNode="tube2" groupIndex="1" color="1 1 1" />
    <sharedLight filename="$data/shared/assets/lights/terraLed/fluorescentTube50W.xml" linkNode="tube3" groupIndex="1" color="1 1 1" />
    <sharedLight filename="$data/shared/assets/lights/terraLed/fluorescentTube50W.xml" linkNode="tube4" groupIndex="1" color="1 1 1" />
    <sharedLight filename="$data/shared/assets/lights/terraLed/fluorescentTube50W.xml" linkNode="tube5" groupIndex="1" color="1 1 1" />
    <sharedLight filename="$data/shared/assets/lights/terraLed/fluorescentTube50W.xml" linkNode="tube6" groupIndex="1" color="1 1 1" />
    <realLights>
      <high>
        <light node="realLightsHigh" groupIndex="1" />
      </high>
    </realLights>
  </lights>
  <i3dMappings>
    <i3dMapping id="clearArea1Start" node="0>0|0" />
    <i3dMapping id="clearArea1Width" node="0>0|0|0" />
    <i3dMapping id="clearArea1Height" node="0>0|0|1" />
    <i3dMapping id="levelArea1Start" node="0>1|0" />
    <i3dMapping id="levelArea1Width" node="0>1|0|0" />
    <i3dMapping id="levelArea1Height" node="0>1|0|1" />
    <i3dMapping id="indoorArea1Start" node="0>2|0" />
    <i3dMapping id="indoorArea1Width" node="0>2|0|0" />
    <i3dMapping id="indoorArea1Height" node="0>2|0|1" />
    <i3dMapping id="testArea1Start" node="0>3|0" />
    <i3dMapping id="testArea1End" node="0>3|0|0" />
    <i3dMapping id="tipOcclusionUpdateArea1Start" node="0>4|0" />
    <i3dMapping id="tipOcclusionUpdateArea1End" node="0>4|0|0" />
    <i3dMapping id="LeftDoor" node="0>7|0" />
    <i3dMapping id="RightDoor" node="0>7|1" />
    <i3dMapping id="DoorTrigger" node="0>7|2" />
    <i3dMapping id="lightSwitch" node="0>8|0" />
    <i3dMapping id="lightTrigger" node="0>8|1" />
    <i3dMapping id="tube1" node="0>8|2|0" />
    <i3dMapping id="tube2" node="0>8|2|1" />
    <i3dMapping id="tube3" node="0>8|2|2" />
    <i3dMapping id="tube4" node="0>8|2|3" />
    <i3dMapping id="tube5" node="0>8|2|4" />
    <i3dMapping id="tube6" node="0>8|2|5" />
    <i3dMapping id="realLightsHigh" node="0>8|3|0" />
  </i3dMappings>
</placeable>
