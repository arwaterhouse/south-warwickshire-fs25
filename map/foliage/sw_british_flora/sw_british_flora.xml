<?xml version="1.0" encoding="utf-8"?>
<!--
    South Warwickshire - British Flora Foliage Layer
    Custom paintable foliage for Cow Parsley and Stinging Nettles.

    i3d node structure expected in sw_british_flora.i3d:
    --------------------------------------------------------
    Scene root
      ├── cowParsley              (top-level child 0  -> blockShape "0>...")
      │   └── cowParsley_v0       (child >0)
      │       ├── cowParsley_LOD0  (child |0  - high-res mesh, ~500-1500 tris)
      │       └── cowParsley_LOD1  (child |1  - low-res mesh,  ~100-300 tris)
      └── stingingNettle          (top-level child 1  -> blockShape "1>...")
          └── stingingNettle_v0   (child >0)
              ├── nettle_LOD0      (child |0  - high-res mesh)
              └── nettle_LOD1      (child |1  - low-res mesh)

    Foliage states:
      State 1 = cowParsley
      State 2 = stingingNettle

    To use the same mesh for both LODs initially (while you build a
    low-poly version), duplicate the imported mesh node and place both
    copies as siblings under the variant TransformGroup.
-->
<foliageType>
    <foliageLayer densityMapChannelOffset="0" numDensityMapChannels="4"
                  numBlocksPerUnit="3.0"
                  shapeSource="sw_british_flora.i3d">

        <foliageStateDefaults
            width="1.0" height="1.0"
            widthVariance="0.25" heightVariance="0.35"
            horizontalPositionVariance="0.4" />

        <!-- LOD 0: full 3-D mesh shown within 20 m -->
        <foliageLodDefaults lod="0" viewDistance="20" blendOutDistance="3" />
        <!-- LOD 1: simplified mesh shown 20–70 m away -->
        <foliageLodDefaults lod="1" viewDistance="70" blendOutDistance="5" />

        <!-- ============================================================
             State 1: Cow Parsley  (Anthriscus sylvestris)
             Tall umbelliferous plant - common on hedgerow banks and verges.
             numBlocksPerUnit kept low to give an open, natural spread.
        ============================================================ -->
        <foliageState name="cowParsley"
                      width="1.3" height="1.4"
                      widthVariance="0.3" heightVariance="0.45"
                      numBlocksPerUnit="2.0">
            <!-- variant 0 (single variant; add more foliageShape blocks
                 for additional mesh variants - game picks one randomly) -->
            <foliageShape>
                <foliageLod blockShape="0>0|0" />  <!-- LOD 0: close mesh -->
                <foliageLod blockShape="0>0|1" />  <!-- LOD 1: distant mesh -->
            </foliageShape>
        </foliageState>

        <!-- ============================================================
             State 2: Stinging Nettle  (Urtica dioica)
             Dense low cover around woodland edges, ditches, and waste ground.
             Higher numBlocksPerUnit for a denser, colony-style appearance.
        ============================================================ -->
        <foliageState name="stingingNettle"
                      width="0.9" height="1.0"
                      widthVariance="0.2" heightVariance="0.35"
                      numBlocksPerUnit="3.5">
            <foliageShape>
                <foliageLod blockShape="1>0|0" />  <!-- LOD 0: close mesh -->
                <foliageLod blockShape="1>0|1" />  <!-- LOD 1: distant mesh -->
            </foliageShape>
        </foliageState>

    </foliageLayer>
</foliageType>
