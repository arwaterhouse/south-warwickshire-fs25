<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="simplePlaceable">
    <storeData>
        <name>
			<en>UK Bale Shed</en>	
		</name>
        <functions>
            <function>$l10n_function_garage</function>
        </functions>
        <image>placeables/FS25_UK_BaleShed/store_UK_BaleShed.dds</image>
        <price>35500</price>
		<dailyUpkeep>5</dailyUpkeep>
        <lifetime>3000</lifetime>
        <rotation>0</rotation>
        <brand>LIZARD</brand>
        <species>placeable</species>
		<category>sheds</category>
		<brush>
			<type>placeable</type>
			<category>buildings</category>
			<tab>sheds</tab>
		</brush>
		<canBeSold>true</canBeSold>
        <showInStore>true</showInStore>
    </storeData>
	
   <base>
        <filename>FS25_UK_BaleShed.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <boughtWithFarmland>true</boughtWithFarmland>
    </base>
	
    <placement useRandomYRotation="false" useManualYRotation="true">
        <testAreas>
            <testArea startNode="testAreaStart" endNode="testAreaEnd" />
        </testAreas>
		
		<sounds>
            <place template="smallImp" pitchScale="1.6"/>
        </sounds>
    </placement>
	
	<testAreas>
        <testArea startNode="testAreaStart" widthNode="testAreaWidth" heightNode="testAreaHeight"/>
    </testAreas>
	
    <clearAreas>
        <clearArea startNode="clearAreaStart" widthNode="clearAreaWidth" heightNode="clearAreaHeight"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="3" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="levelAreaStart" widthNode="levelAreaWidth" heightNode="levelAreaHeight" groundType="concrete"/>
        </levelAreas>
    </leveling>
   
	<indoorAreas>
        <indoorArea startNode="indoorAreaStart" widthNode="indoorAreaWidth" heightNode="indoorAreaHeight"/>
    </indoorAreas>
	
	<tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart" endNode="tipOcclusionUpdateAreaEnd" />
    </tipOcclusionUpdateAreas>
	
	<ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart" endNode="tipOcclusionUpdateAreaEnd" />
        </updateAreas>
    </ai>
	
	<i3dMappings>
		
		<i3dMapping id="testAreaStart" node="0>0|0|0" />
		<i3dMapping id="testAreaEnd" node="0>0|0|0|0" />
		
		<i3dMapping id="clearAreaStart" node="0>0|1|0" />
		<i3dMapping id="clearAreaWidth" node="0>0|1|0|0" />
		<i3dMapping id="clearAreaHeight" node="0>0|1|0|1" />
		
		<i3dMapping id="levelAreaStart" node="0>0|2|0" />
		<i3dMapping id="levelAreaWidth" node="0>0|2|0|0" />
		<i3dMapping id="levelAreaHeight" node="0>0|2|0|1" />
		
		<i3dMapping id="indoorAreaStart" node="0>0|3|0" />
		<i3dMapping id="indoorAreaWidth" node="0>0|3|0|0" />
		<i3dMapping id="indoorAreaHeight" node="0>0|3|0|1" />
		
		<i3dMapping id="tipOcclusionUpdateAreaStart" node="0>0|4|0" />
		<i3dMapping id="tipOcclusionUpdateAreaEnd" node="0>0|4|0|0" />

	</i3dMappings>

</placeable>