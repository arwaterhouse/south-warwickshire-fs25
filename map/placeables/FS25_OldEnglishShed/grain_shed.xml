<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="simplePlaceable" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>Old English Shed</name>
        <functions>
            <function>$l10n_function_garage</function>
        </functions>
        <image>placeables/FS25_OldEnglishShed/store_GrainBarn.dds</image>
        <price>24000</price>
        <dailyUpkeep>25</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>LIZARD</brand>
        <canBeSold>true</canBeSold>
        <showInStore>true</showInStore>
		<species>placeable</species>
        <category>sheds</category>
        <brush>
            <type>placeable</type>
            <category>buildings</category>
            <tab>sheds</tab>
        </brush>
        <vertexBufferMemoryUsage>937472</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>96256</indexBufferMemoryUsage>
        <textureMemoryUsage>7733248</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>GrainShed.i3d</filename>
    </base>

    <placeableType>placeable</placeableType>
	
	<placement useRandomYRotation="false" useManualYRotation="true" >
        <testAreas>
            <testArea startNode="testArea1Start" endNode="testArea1End" />
        </testAreas>
    </placement>

    <clearAreas>
        <clearArea startNode="clearArea1Start" widthNode="clearArea1Width" heightNode="clearArea1Height"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="5" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="levelArea1Start" widthNode="levelArea1Width" heightNode="levelArea1Height" groundType="asphalt"/>
        </levelAreas>
    </leveling>

    <indoorAreas>
        <indoorArea startNode="indoorArea1Start" widthNode="indoorArea1Width" heightNode="indoorArea1Height" />
    </indoorAreas>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateArea1Start" endNode="tipOcclusionUpdateArea1End" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateArea1Start" endNode="tipOcclusionUpdateArea1End" />
        </updateAreas>
    </ai>
	
    <lights>
        <sharedLight filename="$data/shared/assets/lights/terraLed/fluorescentTube50W.xml" linkNode="lightNode01" groupIndex="1">
            <rotationNode name="rotationNode01" rotation="0 0 -15" />
        </sharedLight>
        <sharedLight filename="$data/shared/assets/lights/terraLed/fluorescentTube50W.xml" linkNode="lightNode02" groupIndex="1">
            <rotationNode name="rotationNode01" rotation="0 0 15" />
        </sharedLight>
        <sharedLight filename="$data/shared/assets/lights/terraLed/fluorescentTube50W.xml" linkNode="lightNode03" groupIndex="1">
            <rotationNode name="rotationNode01" rotation="0 0 -15" />
        </sharedLight>
        <sharedLight filename="$data/shared/assets/lights/terraLed/fluorescentTube50W.xml" linkNode="lightNode04" groupIndex="1">
            <rotationNode name="rotationNode01" rotation="0 0 15" />
        </sharedLight>
		<sharedLight filename="$data/shared/assets/lights/terraLed/fluorescentTube50W.xml" linkNode="lightNode05" groupIndex="1">
            <rotationNode name="rotationNode01" rotation="0 0 -15" />
        </sharedLight>
        <sharedLight filename="$data/shared/assets/lights/terraLed/fluorescentTube50W.xml" linkNode="lightNode06" groupIndex="1">
            <rotationNode name="rotationNode01" rotation="0 0 15" />
        </sharedLight>
		<sharedLight filename="$data/shared/assets/lights/terraLed/fluorescentTube50W.xml" linkNode="lightNode07" groupIndex="1">
            <rotationNode name="rotationNode01" rotation="0 0 -15" />
        </sharedLight>
        <sharedLight filename="$data/shared/assets/lights/terraLed/fluorescentTube50W.xml" linkNode="lightNode08" groupIndex="1">
            <rotationNode name="rotationNode01" rotation="0 0 15" />
        </sharedLight>
		
		
		<realLights>
            <low>
                <light node="realLightsLow1" groupIndex="1"/>
            </low>
            <high>
                <light node="realLightsHigh1" groupIndex="1"/>
			</high>
        </realLights>

        <group name="$l10n_action_placeableLightShed" triggerNode="lightTrigger1">
            <sounds>
                <toggle template="lizardFloodLight" innerRadius="50" outerRadius="100" volumeScale="0.2"/>
            </sounds>
        </group>
    </lights>
	
	<animatedObjects>
    		
	    <animatedObject saveId="shedDoor" >
            <animation duration="1.4">
                <part node="shedDoorDoor">
					<keyFrame time="0.12" rotation="0 0 0" />
					<keyFrame time="1" rotation="0 -85 0" />
				</part>
				<part node="shedDoorHandle">
					<keyFrame time="0.00" rotation="0 0 0" />
					<keyFrame time="0.12" rotation="45 0 0" />
					<keyFrame time="0.24" rotation="0 0 0" />
				</part>
            </animation>
            <controls triggerNode="shedDoorTrigger" posAction="ACTIVATE_HANDTOOL" posText="action_openDoor" negText="action_closeDoor" />
            <sounds>
                 <moving linkNode="shedDoor" template="glassDoorLoop" />
                 <posEnd linkNode="shedDoor" template="metalDoorsOpen" />
                 <negEnd linkNode="shedDoor" template="metalDoorsClose" />
            </sounds>
        </animatedObject>
		
		<animatedObject saveId="largeDoor" >
            <animation duration="3">
                <part node="largeDoorLeft">
					<keyFrame time="0" translation="-12.12100029 3.25981975 -0.51726103" />
					<keyFrame time="1" translation="-12.12100029 3.25981975 -2.91936684" />
				</part>
				<part node="largeDoorRight">
					<keyFrame time="0" translation="-12.12100029 3.25981975 0.51231527" />
					<keyFrame time="1" translation="-12.12100029 3.25981975 2.91212058" />
				</part>
            </animation>
            <controls triggerNode="largeDoorTrigger" posAction="ACTIVATE_HANDTOOL" posText="action_openDoor" negText="action_closeDoor" />
            <sounds>
                 <moving linkNode="shedDoor" file="audio/slidingGate.ogg" loops="1" />
                 <posEnd linkNode="shedDoor" template="metalDoorsOpen" />
                 <negEnd linkNode="shedDoor" template="metalDoorsClose" />
            </sounds>
        </animatedObject>
	
	</animatedObjects>	
		
	<i3dMappings>
		<i3dMapping id="clearArea1Start" node="0>11|0|0" />
        <i3dMapping id="clearArea1Width" node="0>11|0|0|0" />
        <i3dMapping id="clearArea1Height" node="0>11|0|0|1" />
        <i3dMapping id="levelArea1Start" node="0>11|1|0" />
        <i3dMapping id="levelArea1Width" node="0>11|1|0|0" />
        <i3dMapping id="levelArea1Height" node="0>11|1|0|1" />
        <i3dMapping id="indoorArea1Start" node="0>11|2|0" />
        <i3dMapping id="indoorArea1Width" node="0>11|2|0|0" />
        <i3dMapping id="indoorArea1Height" node="0>11|2|0|1" />
        <i3dMapping id="testArea1Start" node="0>11|3|0" />
        <i3dMapping id="testArea1End" node="0>11|3|0|0" />
        <i3dMapping id="tipOcclusionUpdateArea1Start" node="0>11|4|0" />
        <i3dMapping id="tipOcclusionUpdateArea1End" node="0>11|4|0|0" />
		
		<i3dMapping id="lightTrigger1" node="0>11|6|0" /> 
		<i3dMapping id="lightNode01" node="0>11|6|2" />
		<i3dMapping id="lightNode02" node="0>11|6|3" />
		<i3dMapping id="lightNode03" node="0>11|6|4" />
		<i3dMapping id="lightNode04" node="0>11|6|5" />
		<i3dMapping id="lightNode05" node="0>11|6|6" />
		<i3dMapping id="lightNode06" node="0>11|6|7" />
		<i3dMapping id="lightNode07" node="0>11|6|8" />
		<i3dMapping id="lightNode08" node="0>11|6|9" />
		
		<i3dMapping id="realLightsLow1" node="0>11|6|10|0" />
		<i3dMapping id="realLightsHigh1" node="0>11|6|10|1" />
		
		<i3dMapping id="shedDoor" node="0>11|5|0" />
		<i3dMapping id="shedDoorTrigger" node="0>11|5|0|0" />
		<i3dMapping id="shedDoorDoor" node="0>11|5|0|1" />
		<i3dMapping id="shedDoorHandle" node="0>11|5|0|1|0" />
		
		<i3dMapping id="largeDoor" node="0>11|5|1" />
		<i3dMapping id="largeDoorTrigger" node="0>11|5|1|0" />
		<i3dMapping id="largeDoorLeft" node="0>11|5|1|1" />
		<i3dMapping id="largeDoorRight" node="0>11|5|1|2" />
		
		</i3dMappings>
</placeable>