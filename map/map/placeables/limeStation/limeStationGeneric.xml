<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="buyingStation" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_shopItem_limeStation</name>
        <image>$data/store/store_empty.png</image>
        <price>0</price>
        <canBeSold>false</canBeSold>
        <showInStore>false</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>PLACEABLE</species>
        <category>placeableMisc</category>
        <brush>
            <type>placeable</type>
            <category>buildings</category>
            <tab>containers</tab>
        </brush>
        <vertexBufferMemoryUsage>155136</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>41984</indexBufferMemoryUsage>
        <textureMemoryUsage>524288</textureMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
    </storeData>

    <base>
        <filename>$data/placeables/brandless/limeStation/limeStation.i3d</filename>
    </base>

    <deletedNodes>
        <deletedNode node="clearAreas"/>
        <deletedNode node="levelAreas"/>
        <deletedNode node="testAreas"/>
        <deletedNode node="silo"/>
        <deletedNode node="visuals"/>
        <deletedNode node="collisions"/>
    </deletedNodes>

    <placement/>

    <clearAreas/>

    <leveling/>

    <indoorAreas />

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart01" endNode="tipOcclusionUpdateAreaEnd01" />
        </updateAreas>
    </ai>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart01" endNode="tipOcclusionUpdateAreaEnd01" />
    </tipOcclusionUpdateAreas>

    <buyingStation node="buyingStation" supportsExtension="false">
        <loadTrigger triggerNode="loadingTrigger" fillTypes="LIME FERTILIZER" fillLitersPerSecond="500" infiniteCapacity="true" aiNode="aiNodeLoading">
            <effectNode effectClass="PipeEffect" effectNode="pipeEffect"      materialType="pipe"           fadeTime="0.5" maxBending="0" shapeScaleSpread="0.8 0.8 1 0" controlPoint="3 0 0 0"/>
            <effectNode                          effectNode="pipeEffectSmoke" materialType="unloadingSmoke" fadeTime="0.5" />
        </loadTrigger>
        <fillType name="LIME FERTILIZER" priceScale="0.8" />
    </buyingStation>

    <hotspots>
        <hotspot type="LOADING" linkNode="mapPosition" teleportNode="teleportNode"/>
    </hotspots>

    <triggerMarkers>
        <triggerMarker node="markerLoading" filename="$data/shared/assets/marker/markerIconLoad.i3d" adjustToGround="true"/>
    </triggerMarkers>

    <i3dMappings>
        <i3dMapping id="clearAreas" node="0>0" />
        <i3dMapping id="clearAreaStart01" node="0>0|0" />
        <i3dMapping id="clearAreaWidth01" node="0>0|0|0" />
        <i3dMapping id="clearAreaHeight01" node="0>0|0|1" />
        <i3dMapping id="levelAreas" node="0>1" />
        <i3dMapping id="levelAreaStart01" node="0>1|0" />
        <i3dMapping id="levelAreaWidth01" node="0>1|0|0" />
        <i3dMapping id="levelAreaHeight01" node="0>1|0|1" />
        <i3dMapping id="testAreas" node="0>2" />
        <i3dMapping id="testAreaStart01" node="0>2|0" />
        <i3dMapping id="testAreaEnd01" node="0>2|0|0" />
        <i3dMapping id="tipOcclusionUpdateAreaStart01" node="0>3|0" />
        <i3dMapping id="tipOcclusionUpdateAreaEnd01" node="0>3|0|0" />
        <i3dMapping id="buyingStation" node="0>4" />
        <i3dMapping id="teleportNode" node="0>4|0" />
        <i3dMapping id="markerLoading" node="0>4|1" />
        <i3dMapping id="mapPosition" node="0>4|2" />
        <i3dMapping id="loadingTrigger" node="0>4|3|0" />
        <i3dMapping id="dischargeNode" node="0>4|3|1" />
        <i3dMapping id="aiNodeLoading" node="0>4|3|2" />
        <i3dMapping id="pipeEffect" node="0>4|3|3|0" />
        <i3dMapping id="pipeEffectSmoke" node="0>4|3|3|1" />
        <i3dMapping id="silo" node="0>5" />
        <i3dMapping id="exactFillRootNode" node="0>5|0|0" />
        <i3dMapping id="unloadingStationAINode" node="0>5|0|1" />
        <i3dMapping id="loadingTriggerSilo" node="0>5|1|0" />
        <i3dMapping id="loadingTriggerAINode" node="0>5|1|1" />
        <i3dMapping id="refillPlayerTrigger" node="0>5|2" />
        <i3dMapping id="refillMarker" node="0>5|3" />
        <i3dMapping id="markerLoadingSilo" node="0>5|4" />
        <i3dMapping id="mapPositionSilo" node="0>5|5" />
        <i3dMapping id="storage" node="0>5|6" />
        <i3dMapping id="infoTrigger" node="0>5|7" />
        <i3dMapping id="visuals" node="0>6" />
        <i3dMapping id="collisions" node="0>7" />
    </i3dMappings>
</placeable>
