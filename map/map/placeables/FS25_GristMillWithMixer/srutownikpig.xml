<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="productionPoint" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../shared/xml/schema/placeable.xsd">
    <storeData>
	<name>
		<en>Grist mill with mixer</en>
		<de>Schrotmühle mit Mischer</de>
	</name>
        <functions>
            <function>$l10n_function_productionPoint</function>
        </functions>
        <image>store_srutownik.dds</image>
        <price>14000</price>
        <lifetime>500</lifetime>
        <dailyUpkeep>25</dailyUpkeep>
		<rotation>0</rotation>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>productionPoints</category>
        <brush>
            <type>placeable</type>
            <category>production</category>
            <tab>factories</tab>
        </brush>
        <vertexBufferMemoryUsage>1013504</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>262400</indexBufferMemoryUsage>
        <textureMemoryUsage>2949120</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>map/placeables/FS25_GristMillWithMixer/srutownik.i3d</filename>
        <boughtWithFarmland>true</boughtWithFarmland>
        <buysFarmland priceScale="1">false</buysFarmland>
        <canBeDeleted>true</canBeDeleted>
        <canBeRenamed>true</canBeRenamed>
	</base>

    <placement useRandomYRotation="false" useManualYRotation="true" >
        <testAreas>
            <testArea startNode="testArea1Start" endNode="testArea1End" />
        </testAreas>

        <sounds>
            <place template="smallImp" />
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearArea1Start" widthNode="clearArea1Width" heightNode="clearArea1Height"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="10" maxSlope="75" maxEdgeAngle="30" >
        <levelAreas>
            <levelArea startNode="levelArea1Start" widthNode="levelArea1Width" heightNode="levelArea1Height" />
        </levelAreas>

        <paintAreas>
            <paintArea startNode="paintArea1Start" widthNode="paintArea1Width" heightNode="paintArea1Height" groundType="dirt"/>
        </paintAreas>
    </leveling>

    <indoorAreas>
        <indoorArea startNode="0>4|0" widthNode="0>4|0|0" heightNode="4|0|1"/>
    </indoorAreas>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateArea1Start" endNode="tipOcclusionUpdateArea1End" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateArea1Start" endNode="tipOcclusionUpdateArea1End" />
        </updateAreas>
    </ai>

    <infoTrigger triggerNode="infoTrigger" />

    <hotspots>
        <hotspot type="PRODUCTION_POINT" linkNode="unloadTriggerMarker" teleportNode="unloadTriggerMarker" />
    </hotspots>

    <dynamicallyLoadedParts />

      <triggerMarkers>
        <triggerMarker node="loadTriggerMarker"        filename="$data/shared/assets/marker/markerIconLoad.i3d" id="LOAD"        adjustToGround="false" />
        <triggerMarker node="unloadTriggerMarker"      filename="$data/shared/assets/marker/markerIconUnload.i3d" id="UNLOAD"    adjustToGround="true"  />
        <triggerMarker node="playerTriggerMarker"  	   filename="$data/shared/assets/marker/markerIconWrench.i3d" id="WRENCH"    adjustToGround="true" />
    </triggerMarkers>		

    <lights />

    <productionPoint>
        <productions>
            <production id="PIGFOOD1" name="$l10n_fillType_pigFood" cyclesPerHour="5000" costsPerActiveHour="5">
                <inputs>
                    <input fillType="WHEAT" amount="2" />
                    <input fillType="BARLEY" amount="1" />
                </inputs>
                <outputs>
                    <output fillType="PIGFOOD" amount="3" />
                </outputs>
            </production>

            <production id="PIGFOOD2" name="$l10n_fillType_pigFood" cyclesPerHour="5000" costsPerActiveHour="5">
                <inputs>
                    <input fillType="WHEAT" amount="2" />
                    <input fillType="CANOLA" amount="1" />
                    <input fillType="MAIZE" amount="1" />
                </inputs>
                <outputs>
                    <output fillType="PIGFOOD" amount="4" />
                </outputs>
            </production>

            <production id="PIGFOOD3" name="$l10n_fillType_pigFood" cyclesPerHour="5000" costsPerActiveHour="5">
                <inputs>
                    <input fillType="WHEAT" amount="2" />
                    <input fillType="BARLEY" amount="1" />
                    <input fillType="OAT" amount="1" />
                </inputs>
                <outputs>
                    <output fillType="PIGFOOD" amount="4" />
                </outputs>
            </production>
						
        </productions>

        <storage isExtension="false" fillLevelSyncThreshold="50">
            <capacity fillType="WHEAT"   	capacity="4000" />
            <capacity fillType="BARLEY" 	capacity="2000" />
            <capacity fillType="CANOLA"     	capacity="2000" />
            <capacity fillType="OAT"     	capacity="2000" />
            <capacity fillType="MAIZE"     	capacity="3000" />
            <capacity fillType="PIGFOOD" capacity="1100" />						
        </storage>

        <sellingStation node="sellingStation" supportsExtension="false">
            <unloadTrigger exactFillRootNode="unloadTrigger" fillTypes="WHEAT PIGFOOD OAT CANOLA BARLEY MAIZE"/>
        </sellingStation>
		
          <loadingStation>
	    <loadTrigger triggerNode="0>12|0" fillLitersPerSecond="50" dischargeNode="dischargeNode" fillTypes="PIGFOOD" aiNode="0>12|1">
                <effectNode effectClass="PipeEffect" effectNode="0>12|3|0"      materialType="pipe"           fadeTime="0.5" maxBending="0" controlPoint="4.8 0 0 0" />
                <effectNode                          effectNode="0>12|3|1" materialType="unloadingSmoke" fadeTime="0.5" />
        </loadTrigger>
       </loadingStation>

        <playerTrigger node="playerTrigger" />
		
		<animationNodes>
					<animationNode node="0>0|3" rotAxis="2" rotSpeed="2000" />
					<animationNode node="0>0|2" rotAxis="3" rotSpeed="-2000" />
		</animationNodes>

        <sounds>
            <active template="grainMillWork" linkNode="0>" />
        </sounds>
    </productionPoint>

    <i3dMappings>
        <i3dMapping id="clearArea1Start" node="0>1|0" />
        <i3dMapping id="clearArea1Width" node="0>1|0|0" />
        <i3dMapping id="clearArea1Height" node="0>1|0|1" />
        <i3dMapping id="levelArea1Start" node="0>2|0" />
        <i3dMapping id="levelArea1Width" node="0>2|0|0" />
        <i3dMapping id="levelArea1Height" node="0>2|0|1" />
        <i3dMapping id="paintArea1Start" node="0>3|0" />
        <i3dMapping id="paintArea1Width" node="0>3|0|0" />
        <i3dMapping id="paintArea1Height" node="0>3|0|1" />
        <i3dMapping id="testArea1Start" node="0>5|0" />
        <i3dMapping id="testArea1End" node="0>5|0|0" />
        <i3dMapping id="tipOcclusionUpdateArea1Start" node="0>6|0" />
        <i3dMapping id="tipOcclusionUpdateArea1End" node="0>6|0|0" />
        <i3dMapping id="infoTrigger" node="0>7" />
        <i3dMapping id="sellingStation" node="0>11" />
        <i3dMapping id="unloadTrigger" node="0>11|0" />
        <i3dMapping id="unloadTriggerMarker" node="0>11|0|0" />
        <i3dMapping id="loadingTrigger" node="0>12|0" />
        <i3dMapping id="loadTriggerMarker" node="0>12|4" />
        <i3dMapping id="dischargeNode" node="0>12|2" />
        <i3dMapping id="pipeEffect" node="0>12|3|0" />
        <i3dMapping id="pipeEffectSmoke" node="0>12|3|1" />
        <i3dMapping id="playerTrigger" node="0>13|0" />
        <i3dMapping id="playerTriggerMarker" node="0>13|0|0" />
        <i3dMapping id="loadTriggerAiNode" node="0>12|1" />
	</i3dMappings>
</placeable>
