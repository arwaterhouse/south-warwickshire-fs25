<?xml version='1.0' encoding='utf-8'?>
<placeable xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" type="simplePlaceable" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>UK Machinery Shed</name>
        <functions>
            <function>$l10n_function_garage</function>
        </functions>
        <image>store/store_machineShed02.dds</image>
        <price>30000</price>
        <dailyUpkeep>5</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>EASYSHEDS</brand>
        <species>PLACEABLE</species>
        <category>sheds</category>
        <brush>
            <type>placeable</type>
            <category>buildings</category>
            <tab>sheds</tab>
        </brush>
        <canBeSold>true</canBeSold>
        <showInStore>true</showInStore>
        
        <vertexBufferMemoryUsage>1249792</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>246016</indexBufferMemoryUsage>
        <textureMemoryUsage>14942208</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/machineShed02/machineShed02.i3d</filename>
        <boughtWithFarmland>true</boughtWithFarmland>
        <canBeRenamed>true</canBeRenamed>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true">
        <testAreas>
            <testArea startNode="testAreaStart01" endNode="testAreaEnd01" />
        </testAreas>

        <sounds>
            <place template="medImp" />
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearAreaStart01" widthNode="clearAreaWidth01" heightNode="clearAreaHeight01" />
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="10" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="levelAreaStart01" widthNode="levelAreaWidth01" heightNode="levelAreaHeight01" groundType="asphalt" />
        </levelAreas>
    </leveling>

    <indoorAreas>
        <indoorArea startNode="indoorAreaStart01" widthNode="indoorAreaWidth01" heightNode="indoorAreaHeight01" />
    </indoorAreas>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart01" endNode="tipOcclusionUpdateAreaEnd01" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart01" endNode="tipOcclusionUpdateAreaEnd01" />
        </updateAreas>
    </ai>
    
    <animatedObjects>
        <animatedObject saveId="shedDoor01">
            <animation duration="4.0">
                <part node="0&gt;5|0|1|1">
                    <keyFrame time="0.0" translation="0 0 0" />
                    <keyFrame time="1.0" translation="0 0 -5.365" />
                </part>
            </animation>
            <controls triggerNode="0&gt;5|0|1|0" posAction="ACTIVATE_HANDTOOL" posText="action_openGate" negText="action_closeGate" />
            <sounds>
                <moving linkNode="0&gt;5|0|1|1" template="slidingGateWoodLoop" />
                <posEnd linkNode="0&gt;5|0|1|1" template="woodDoorOpen" />
                <negEnd linkNode="0&gt;5|0|1|1" template="woodDoorClose" />
            </sounds>
         </animatedObject>
         <animatedObject saveId="light">
            <animation duration="1">
                <part node="0&gt;5|0|3|0|0">
                    <keyFrame time="0" visibility="false" />
                    <keyFrame time="0.1" visibility="true" />
                </part>
                <part node="0&gt;5|0|3|1|0">
                    <keyFrame time="0" visibility="false" />
                    <keyFrame time="0.2" visibility="true" />
                </part>
				<part node="0&gt;5|0|3|2|0">
                    <keyFrame time="0" visibility="false" />
                    <keyFrame time="0.3" visibility="true" />
                </part>
				<part node="0&gt;5|0|3|3|0">
                    <keyFrame time="0" visibility="false" />
                    <keyFrame time="0.2" visibility="true" />
                </part>
			</animation>    
                 <controls triggerNode="0&gt;5|0|3|6" posAction="ACTIVATE_HANDTOOL" posText="$l10n_action_lightOn" negText="$l10n_action_lightOut" />
				 <sounds>
					<moving linknode="0&gt;5|0|3|0|0" template="lizardFloodLight" />
					<posEnd linknode="0&gt;5|0|3|0|0" template="lizardFloodLight" />
					<negEnd linknode="0&gt;5|0|3|0|0" template="lizardFloodLight" />
				 </sounds>
        </animatedObject>
     </animatedObjects>
     
     
    
    

    <i3dMappings>
        <i3dMapping id="clearAreaStart01" node="0&gt;0|0" />
        <i3dMapping id="clearAreaWidth01" node="0&gt;0|0|0" />
        <i3dMapping id="clearAreaHeight01" node="0&gt;0|0|1" />
        <i3dMapping id="levelAreaStart01" node="0&gt;1|0" />
        <i3dMapping id="levelAreaWidth01" node="0&gt;1|0|0" />
        <i3dMapping id="levelAreaHeight01" node="0&gt;1|0|1" />
        <i3dMapping id="indoorAreaStart01" node="0&gt;2|0" />
        <i3dMapping id="indoorAreaWidth01" node="0&gt;2|0|0" />
        <i3dMapping id="indoorAreaHeight01" node="0&gt;2|0|1" />
        <i3dMapping id="testAreaStart01" node="0&gt;3|0" />
        <i3dMapping id="testAreaEnd01" node="0&gt;3|0|0" />
        <i3dMapping id="tipOcclusionUpdateAreaStart01" node="0&gt;4|0" />
        <i3dMapping id="tipOcclusionUpdateAreaEnd01" node="0&gt;4|0|0" />
    </i3dMappings>
</placeable>