				</part> 				
			  				
			</animation>
			<controls triggerNode="gate2Trigger" posAction="ACTIVATE_HANDTOOL" posText="action_openGate" negText="action_closeGate" />
			<sounds>
				<moving linkNode="gate2Sound" template="fenceMetalLoop" />
				<posEnd linkNode="gate2Sound" template="fenceMetalOpen" />
				<negEnd linkNode="gate2Sound" template="fenceMetalClose" />
			</sounds>
        </animatedObject>
		
		<animatedObject saveId="gate03" >
            <animation duration="3">
				<part node="gate3">
					<keyFrame time="0.12" rotation="0 0 0" />
					<keyFrame time="1" rotation="0 100 0" />
				</part>
							
				<part node="gate3Latch">
					<keyFrame time="0" translation="3.71390009 0.105694 -0.00289917" />
					<keyFrame time="0.12" translation="3.6276381 0.105694 -0.00289917" />
				</part> 				
			  				
			</animation>
			<controls triggerNode="gate3Trigger" posAction="ACTIVATE_HANDTOOL" posText="action_openGate" negText="action_closeGate" />
			<sounds>
				<moving linkNode="gate3Sound" template="fenceMetalLoop" />
				<posEnd linkNode="gate3Sound" template="fenceMetalOpen" />
				<negEnd linkNode="gate3Sound" template="fenceMetalClose" />
			</sounds>
        </animatedObject>
	
	</animatedObjects> 

