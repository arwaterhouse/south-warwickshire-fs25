<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="cowHusbandryManure" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>            
           <en>UK Large Cattle Shed</en> 
        </name>
		<image>store_ukLargeBeefShed.dds</image>
        <price>120000</price>
        <functions>
            <function>$l10n_function_animalPenCow</function>
        </functions>
        <lifetime>1000</lifetime>
        <dailyUpkeep>35</dailyUpkeep>
        <rotation>0</rotation>
        <brand>LIZARD</brand>
        <species>placeable</species>
        <category>animalpens</category>
        <brush>
            <type>placeable</type>
            <category>animals</category>
            <tab>cows</tab>
        </brush>
    </storeData>

    <base>
        <filename>map/placeables/FS25_UK_LargeBeefShed/FS25_UK_LargeBeefShed.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <boughtWithFarmland>true</boughtWithFarmland>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true">
        <testAreas>
            <testArea startNode="testArea1Start" endNode="testArea1End" />
        </testAreas>

        <sounds>
            <place template="largeImp" />
            <placeLayered template="cowLayer" />
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearArea1Start" widthNode="clearArea1Width" heightNode="clearArea1Height"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="10" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="levelArea1Start" widthNode="levelArea1Width" heightNode="levelArea1Height" />
        </levelAreas>

        <paintAreas>
			<paintArea startNode="paintArea1Start" widthNode="paintArea1Width" heightNode="paintArea1Height" groundType="animalMud"/>
            <paintArea startNode="paintArea2Start" widthNode="paintArea2Width" heightNode="paintArea2Height" groundType="animalMud"/>
			<paintArea startNode="paintArea3Start" widthNode="paintArea3Width" heightNode="paintArea3Height" groundType="concrete"/>
			<paintArea startNode="paintArea4Start" widthNode="paintArea4Width" heightNode="paintArea4Height" groundType="concrete"/>
        </paintAreas>
    </leveling>

    <indoorAreas>
        <indoorArea startNode="indoorArea1Start" widthNode="indoorArea1Width" heightNode="indoorArea1Height"/>
    </indoorAreas>

    <triggerMarkers>
        <triggerMarker node="markerFood"         filename="$data/shared/assets/marker/markerIconFood.i3d" />
        <triggerMarker node="markerAnimals"      filename="$data/shared/assets/marker/markerIconAnimals.i3d" />
        <triggerMarker node="markerBales" 		 filename="$data/shared/assets/marker/markerIconBales.i3d" />
		<triggerMarker node="markerLiquidManure" filename="$data/shared/assets/marker/markerIconSlurry.i3d" />
    </triggerMarkers>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateArea1Start" endNode="tipOcclusionUpdateArea1End" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateArea1Start" endNode="tipOcclusionUpdateArea1End" />
        </updateAreas>
    </ai>

    <hotspots>
        <hotspot type="COW" teleportNode="teleportNode" />
    </hotspots>

    <infoTrigger triggerNode="infoTrigger" />

    <husbandry saveId="Animals_COW" hasStatistics="false">
        <storage node="storage" fillTypes="STRAW MANURE LIQUIDMANURE" isExtension="false">
            <capacity fillType="STRAW" capacity="38000" />
            <capacity fillType="MANURE" capacity="0" />
			<capacity fillType="LIQUIDMANURE" capacity="100000" />
        </storage>

        <unloadingStation supportsExtension="true" storageRadius="65" hideFromPricesMenu="true">
            <unloadTrigger exactFillRootNode="exactFillRootNodeStraw" fillTypes="STRAW" />
            <unloadTrigger fillTypes="MANURE LIQUIDMANURE" />
        </unloadingStation>

		<loadingStation supportsExtension="true" storageRadius="50" fillTypes="MANURE">
			<loadTrigger triggerNode="lqiuidManureTrigger" fillTypes="LIQUIDMANURE" fillLitersPerSecond="2000" aiNode="aiLoadingNodeLiquidManure" />
		</loadingStation>

        <animals type="COW" maxNumAnimals="80" >
            <navigation rootNode="navigationRootNode" filename="navMesh.i3d" />
            <loadingTrigger node="loadingTrigger" />
        </animals>

        <straw>
            <manure factor="1.5" />
            <strawPlane node="strawPlane" minY="-0.025" maxY="0.044" colorChange="false" />
        </straw>

        <water automaticWaterSupply="true" />

        <liquidManure />

        <food capacity="54000">
            <foodPlaces>
                <foodPlace node="foodPlace01" />
                <foodPlace node="foodPlace02" />
                <foodPlace node="foodPlace03" />
                <foodPlace node="foodPlace04" />
                <foodPlace node="foodPlace05" />
                <foodPlace node="foodPlace06" />
                <foodPlace node="foodPlace07" />
                <foodPlace node="foodPlace08" />
				<foodPlace node="foodPlace09" />
				<foodPlace node="foodPlace10" />
				<foodPlace node="foodPlace11" />
				<foodPlace node="foodPlace12" />
            </foodPlaces>
            <dynamicFoodPlane node="fillVolumeFood" defaultFillType="forage" maxAllowedHeapAngle="60" maxSubDivEdgeLength="0.5" capacity="60000"/>
            <unloadTrigger exactFillRootNode="exactFillRootNodeFood" />
            <baleTrigger triggerNode="baleTrigger"/>
        </food>
    </husbandry>
	
    <manureHeap node="manureHeap" capacity="25000" isExtension="false" >
        <area startNode="tipAreaStart" widthNode="tipAreaWidth" heightNode="tipAreaHeight" activationTriggerNode="activationTrigger" />
        <clearArea startNode="clearAreaStart" widthNode="clearAreaWidth" heightNode="clearAreaHeight" />

        <loadingStation storageRadius="15" supportsExtension="false">
            <loadTrigger triggerNode="loadingTriggerManure" aiNode="loadingTriggerAINodeManure" fillTypes="MANURE" fillLitersPerSecond="2000" />
        </loadingStation>
    </manureHeap>
	
	<animatedObjects>

		<animatedObject saveId="gate01" >
            <animation duration="3">
				<part node="gate1">
					<keyFrame time="0.12" rotation="0 0 0" />
					<keyFrame time="1" rotation="0 100 0" />
				</part>
							
				<part node="gate1Latch">
					<keyFrame time="0" translation="3.71390009 0.105694 -0.00289917" />
					<keyFrame time="0.12" translation="3.64973831 0.105694 -0.00289917" />
				</part> 				
			  				
			</animation>
			<controls triggerNode="gate1Trigger" posAction="ACTIVATE_HANDTOOL" posText="action_openGate" negText="action_closeGate" />
			<sounds>
				<moving linkNode="gate1Sound" template="fenceMetalLoop" />
				<posEnd linkNode="gate1Sound" template="fenceMetalOpen" />
				<negEnd linkNode="gate1Sound" template="fenceMetalClose" />
			</sounds>
        </animatedObject>
		
