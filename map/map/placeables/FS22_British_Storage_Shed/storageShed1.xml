<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="simplePlaceable" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>
		<en>Vehicle storage shed</en>
		<de>Lagerschuppen für Fahrzeuge</de>
		</name>
		<functions>
            <function>$l10n_function_garage</function>
        </functions>
        <image>store_storageShed1.dds</image>
        <price>25000</price>
		<dailyUpkeep>25</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
         <brand>NONE</brand>
        <species>placeable</species>
        <category>sheds</category>
        <brush>
            <type>placeable</type>
            <category>buildings</category>
            <tab>sheds</tab>
        </brush>
        <vertexBufferMemoryUsage>902912</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>112896</indexBufferMemoryUsage>
        <textureMemoryUsage>3145728</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>map/placeables/FS22_British_Storage_Shed/storageShed1.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <boughtWithFarmland>true</boughtWithFarmland>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" >
        <testAreas>
            <testArea startNode="startTest" endNode="endTest" />
        </testAreas>

        <sounds>
            <place template="smallImp" />
        </sounds>
    </placement>

	<clearAreas>
        <clearArea startNode="levelAreaStart" widthNode="levelAreaWidth" heightNode="levelAreaHeight"/>
        <clearArea startNode="levelAreaStart2" widthNode="levelAreaWidth2" heightNode="levelAreaHeight2"/>
    </clearAreas>
	
    <leveling requireLeveling="true" maxSmoothDistance="5" maxSlope="30" maxEdgeAngle="20" >
        <levelAreas>
            <levelArea startNode="levelAreaStart" widthNode="levelAreaWidth" heightNode="levelAreaHeight" groundType="asphalt"/>
            <levelArea startNode="levelAreaStart2" widthNode="levelAreaWidth2" heightNode="levelAreaHeight2" groundType="dirt"/>
        </levelAreas>
    </leveling>

    <animatedObjects>	
		<animatedObject index="door">
				<animation initialTime="0" duration="2">
					<part node="vrata_levo">
						<keyFrame time="0.0" translation="0 0 0"/>
						<keyFrame time="1.0" translation="2.09 0 0"/>
					</part>
					<part node="vrata_desno">
						<keyFrame time="0.0" translation="0 0 0"/>
						<keyFrame time="1.0" translation="-2.363 0 0"/>
					</part>
				</animation>
				<controls triggerNode="playerTriggerDoor" posAction="ACTIVATE_HANDTOOL" posText="action_openDoor" negText="action_closeDoor"/>
				<sounds>
					<moving file="$data/sounds/prefab/gate/garageDoorLoop.wav" loops="0" linkNode="1" volume="0.8" radius="25" innerRadius="3" fadeOut="0.25"/>
					<posEnd template="metalDoorsOpen" linkNode="1" volume="0.8" radius="25" innerRadius="3"/>
					<negEnd template="metalDoorsClose" linkNode="1" volume="0.8" radius="25" innerRadius="3"/>
				</sounds>
			</animatedObject>	
			<animatedObject index="light01">
				<animation duration="0.5">
					<part node="lightVis1"> 
						<keyFrame time="0.5" visibility="false" />
						<keyFrame time="0.55" visibility="true" />
					</part>
					<part node="lightVis2"> 
						<keyFrame time="0.5" visibility="false" />
						<keyFrame time="0.55" visibility="true" />
					</part>
				</animation>
				<controls triggerNode="playerTriggerLight01" posAction="ACTIVATE_HANDTOOL" posText="action_turnOnLight" negText="action_turnOffLight"/>
			</animatedObject>
			<animatedObject index="light02">
				<animation duration="0.5">
					<part node="lightVis3"> 
						<keyFrame time="0.5" visibility="false" />
						<keyFrame time="0.55" visibility="true" />
					</part>
					<part node="lightVis4"> 
						<keyFrame time="0.5" visibility="false" />
						<keyFrame time="0.55" visibility="true" />
					</part>
					<part node="lightVis5"> 
						<keyFrame time="0.5" visibility="false" />
						<keyFrame time="0.55" visibility="true" />
					</part>
				</animation>
				<controls triggerNode="playerTriggerLight02" posAction="ACTIVATE_HANDTOOL" posText="action_turnOnLight" negText="action_turnOffLight"/>
			</animatedObject>
		</animatedObjects>
		
    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="startTest" endNode="endTest" />
    </tipOcclusionUpdateAreas>

    <indoorAreas>
        <indoorArea startNode="start" widthNode="width" heightNode="height"/>
    </indoorAreas>
	
	    <ai>
        <updateAreas>
            <updateArea startNode="startTest" endNode="endTest" />
        </updateAreas>
    </ai>

	<i3dMappings>
		<i3dMapping id="storageShed1" node="0>" />
		<i3dMapping id="shedSilo" node="0>0" />
		<i3dMapping id="main" node="0>0|0" />
		<i3dMapping id="window" node="0>0|1" />
		<i3dMapping id="areas" node="0>1" />
		<i3dMapping id="start" node="0>1|0" />
		<i3dMapping id="width" node="0>1|1" />
		<i3dMapping id="height" node="0>1|2" />
		<i3dMapping id="testAreas" node="0>2" />
		<i3dMapping id="startTest" node="0>2|0" />
		<i3dMapping id="endTest" node="0>2|0|0" />
		<i3dMapping id="levelAreas" node="0>3" />
		<i3dMapping id="levelArea1" node="0>3|0" />
		<i3dMapping id="levelAreaStart" node="0>3|0|0" />
		<i3dMapping id="levelAreaWidth" node="0>3|0|1" />
		<i3dMapping id="levelAreaHeight" node="0>3|0|2" />
		<i3dMapping id="levelAreaStart2" node="0>3|1|0" />
		<i3dMapping id="levelAreaWidth2" node="0>3|1|1" />
		<i3dMapping id="levelAreaHeight2" node="0>3|1|2" />
		<i3dMapping id="door" node="0>4" />
		<i3dMapping id="vrata_levo" node="0>4|0" />
		<i3dMapping id="vrata_desno" node="0>4|1" />
		<i3dMapping id="playerTriggerDoor" node="0>4|2" />
		<i3dMapping id="light01" node="0>5" />
		<i3dMapping id="lightVis3" node="0>5|0|0|0" />
		<i3dMapping id="lightVis4" node="0>5|0|1|0" />
		<i3dMapping id="lightVis5" node="0>5|0|2|0|0" />
		<i3dMapping id="powerSwitch" node="0>5|1" />
		<i3dMapping id="playerTriggerLight02" node="0>5|2" />
		<i3dMapping id="light02" node="0>6" />
		<i3dMapping id="lightVis1" node="0>6|0|0|0" />
		<i3dMapping id="lightVis2" node="0>6|0|1|0" />
		<i3dMapping id="powerSwitch" node="0>6|1" />
		<i3dMapping id="playerTriggerLight01" node="0>6|2" />
		<i3dMapping id="emissive01" node="0>5|0|0|0|0" />
		<i3dMapping id="spotLight01" node="0>5|0|0|0|1" />
		<i3dMapping id="emissive02" node="0>5|0|1|0|0" />
		<i3dMapping id="spotLight02" node="0>5|0|1|0|1" />
	</i3dMappings>
</placeable>