<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="cowHusbandry" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>UK Cow Shed</name>
        <image>store_cowShed.dds</image>
        <price>40000</price>
        <functions>
            <function>$l10n_function_animalPenCow</function>
        </functions>
        <lifetime>1000</lifetime>
        <dailyUpkeep>20</dailyUpkeep>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>animalpens</category>
        <canBeSold>true</canBeSold>
        <showInStore>true</showInStore>
		<brush>
            <type>placeable</type>
            <category>animals</category>
            <tab>cows</tab>
        </brush>
        
        <vertexBufferMemoryUsage>2954752</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>558080</indexBufferMemoryUsage>
        <textureMemoryUsage>17956864</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>map/placeables/FS25_UK_CowShed/cowShed.i3d</filename>
		<canBeRenamed>true</canBeRenamed>
        <boughtWithFarmland>false</boughtWithFarmland>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true">
        <testAreas>
            <testArea startNode="6|0" endNode="6|0|0" />
        </testAreas>

        <sounds>
            <place template="smallImp" />
			<placeLayered template="cowLayer" />
        </sounds>
    </placement>

    <indoorAreas>
        <indoorArea startNode="4|0" widthNode="4|0|0" heightNode="4|0|1"/>
    </indoorAreas>

    <clearAreas>
        <clearArea startNode="2|0" widthNode="2|0|0" heightNode="2|0|1"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="10" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="3|0" widthNode="3|0|0" heightNode="3|0|1"/>
        </levelAreas>
    </leveling>
	
	<triggerMarkers>
        <triggerMarker node="0>9|0"    filename="$data/shared/assets/marker/markerIconMilk.i3d" id="LOAD" />
        <triggerMarker node="0>13|3"    filename="$data/shared/assets/marker/markerIconFood.i3d" id="UNLOAD" />
        <triggerMarker node="0>13|1"    filename="$data/shared/assets/marker/markerIconAnimals.i3d" id="ANIMALS" />
        <triggerMarker node="0>10|0" 	filename="$data/shared/assets/marker/markerIconSlurry.i3d" id="LOAD" />
		<triggerMarker node="0>13|4" 	filename="$data/shared/assets/marker/markerIconLoad.i3d" id="LOAD" />
	</triggerMarkers>


    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="5|0" endNode="6|0|0" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="5|0" endNode="5|0|0" />
        </updateAreas>
    </ai>
	
	<hotspots>
        <hotspot type="COW" teleportNode="0>16" />
    </hotspots>
	
	

    <animatedObjects>
		
        

        <!-- Lights -->
        <animatedObject saveId="light" >
            <animation duration="1">
                <part node="0>1|0|0">
                    <keyFrame time="0" visibility="false" />
                    <keyFrame time="0.1" visibility="true" />
                </part>
                <part node="0>1|1|0">
                    <keyFrame time="0" visibility="false" />
                    <keyFrame time="0.2" visibility="true" />
                </part>
				<part node="0>1|2|0">
                    <keyFrame time="0" visibility="false" />
                    <keyFrame time="0.3" visibility="true" />
                </part>
				<part node="0>1|3|0">
                    <keyFrame time="0" visibility="false" />
                    <keyFrame time="0.2" visibility="true" />
                </part>
                <part node="0>1|4|0">
                    <keyFrame time="0" visibility="false" />
                    <keyFrame time="0.2" visibility="true" />
                </part>
				<part node="0>1|5|0">
                    <keyFrame time="0" visibility="false" />
                    <keyFrame time="0.4" visibility="true" />
                </part>
                <part node="0>1|6|0">
                    <keyFrame time="0" visibility="false" />
                    <keyFrame time="0.4" visibility="true" />
                </part>
                <part node="0>1|7|0">
                    <keyFrame time="0" visibility="false" />
                    <keyFrame time="0.4" visibility="true" />
                </part>
             </animation>    
                 <controls triggerNode="0>1|10" posAction="ACTIVATE_HANDTOOL" posText="Light On" negText="Light Off" />
				 <sounds>
					<moving linknode="0>1|6" template="lizardFloodLight" />
					<posEnd linknode="0>1|6" template="lizardFloodLight" />
					<negEnd linknode="0>1|6" template="lizardFloodLight" />
				 </sounds>
        </animatedObject>
          <animatedObject saveId="doubleGate" >
                     <animation duration="9">
                        <part node="0>0|0|4|0|3">
                            <keyFrame time="0" rotation="0 0 0" />
					        <keyFrame time="0.2" rotation="-171.676 0 0" />
                        </part>
                        <part node="0>0|0|4|0">
                            <keyFrame time="0.15" rotation="0 0 0"/>
					        <keyFrame time="1" rotation="0 90 0"/>
                        </part>
                        <part node="0>0|0|4|1">
                            <keyFrame time="0.15" rotation="0 0 0"/>
					        <keyFrame time="1" rotation="0 -90 0"/>
                        </part>
                    </animation>
                    <controls triggerNode="0>0|0|4|2" posAction="ACTIVATE_HANDTOOL" posText="action_openDoor" negText="action_closeDoor" />
                    <sounds>
                        <posEnd linkNode="0>0|0|4|0|3" template="fenceOpen" />
                        <negEnd linkNode="0>0|0|4|0|3" template="fenceClose" />
                    </sounds>
            </animatedObject>
            
	</animatedObjects>
	
	<infoTrigger triggerNode="0>14" />

    <husbandry saveId="Animals_COW" hasStatistics="false">
        <storage node="0>17" fillTypes="LIQUIDMANURE MILK STRAW MANURE" isExtension="false">
            <capacity fillType="LIQUIDMANURE" capacity="500000" />
            <capacity fillType="MILK" capacity="30000" />
			<capacity fillType="BUFFALOMILK"  capacity="30000" />
            <capacity fillType="STRAW" capacity="40000" /> 
            <capacity fillType="MANURE" capacity="50000" />
        </storage>

        <unloadingStation supportsExtension="true" storageRadius="100" hideFromPricesMenu="true">
            <unloadTrigger exactFillRootNode="0>8|0" fillTypes="STRAW" />
            <baleTrigger triggerNode="0>8|2" fillTypes="STRAW"/>
            <unloadTrigger fillTypes="MANURE MILK BUFFALOMILK LIQUIDMANURE" />
        </unloadingStation>

        <loadingStation supportsExtension="true" storageRadius="50">
            <loadTrigger triggerNode="0>10|0" fillTypes="LIQUIDMANURE" fillLitersPerSecond="500" />
            <loadTrigger triggerNode="0>09|0" fillTypes="MILK BUFFALOMILK" fillLitersPerSecond="500" />
			<loadTrigger triggerNode="0>18|0" fillTypes="MANURE" fillLitersPerSecond="2000" />
        </loadingStation>

        <animals type="COW" maxNumAnimals="100" maxNumVisualAnimals="30">
            <navigation rootNode="0>12" filename="navigationMesh.i3d" />
            <loadingTrigger node="0>15" />
        </animals>

        <straw>
            <manure factor="1.5" />
            <strawPlane node="0>8|1" minY="-0.419" maxY="-0.271" colorChange="false" />
        </straw>

        <water automaticWaterSupply="true" />

        <liquidManure />

		<food capacity="40000">
            <foodPlaces>
                <foodPlace node="0>7|2|0" />
                <foodPlace node="0>7|2|1" />
                <foodPlace node="0>7|2|2" />
                <foodPlace node="0>7|2|3" />
                <foodPlace node="0>7|2|4" />
                <foodPlace node="0>7|2|5" />
            </foodPlaces>
            <dynamicFoodPlane node="0>7|0" defaultFillType="forage" />
            <unloadTrigger exactFillRootNode="0>7|1" />
            <baleTrigger triggerNode="0>7|3"/>
        </food>

    </husbandry>

</placeable>