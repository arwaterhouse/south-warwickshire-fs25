<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="sellingStation" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_redHorseManure</name>
        <image>$data/placeables/shared/sellingStationGeneric/store_sellingStationGeneric.dds</image>
        <price>1</price>
        <canBeSold>false</canBeSold>
        <showInStore>false</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <dailyUpkeep>0</dailyUpkeep>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>sellingPoints</category>
        <brush>
            <type>placeable</type>
            <category>production</category>
            <tab>sellingPoints</tab>
        </brush>

        <vertexBufferMemoryUsage>222464</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>33792</indexBufferMemoryUsage>
        <textureMemoryUsage>2162688</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>map/placeables/sellingStationGeneric/sellingStationGeneric.i3d</filename>
	</base>

    <placement useRandomYRotation="false" useManualYRotation="true" />

    <clearAreas></clearAreas>

    <leveling></leveling>

    <indoorAreas></indoorAreas>

    <ai>
        <updateAreas/>
        <splines>
            <spline node="aiSpline" />
        </splines>
    </ai>

    <hotspots>
        <hotspot type="LOADING" linkNode="loadMarkerTrailer" teleportNode="loadMarkerTrailer" />
    </hotspots>



    <triggerMarkers>
        <triggerMarker node="loadMarkerTrailer" filename="$data/shared/assets/marker/markerIconLoad.i3d"/>
    </triggerMarkers>

    <buyingStation node="loadStationTrailer" supportsExtension="false">
        <loadTrigger triggerNode="loadNodeTrailer" fillTypes="MANURE" fillLitersPerSecond="2000" infiniteCapacity="true" aiNode="loadNodeAI"/>
        <fillType name="MANURE" priceScale="1.1" />
    </buyingStation>

    <sellingStation appearsOnStats="true" supportsExtension="false" litersForFullPriceDrop="200000" fullPriceRecoverHours="48">
        <unloadTrigger exactFillRootNode="unloadNodeTrailer" fillTypes="MANURE" priceScale="1" aiNode="unloadNodeAI"/>
    </sellingStation>

    <i3dMappings>
        <i3dMapping id="loadStationTrailer" node="0>0" />
        <i3dMapping id="loadNodeTrailer" node="0>0|3" />
        <i3dMapping id="loadMarkerTrailer" node="0>0|1" />
        <i3dMapping id="loadNodeAI" node="0>0|2" />
        <i3dMapping id="unloadNodeTrailer" node="0>0|0" />
        <i3dMapping id="unloadNodeAI" node="0>0|2" />
        <i3dMapping id="aiSpline" node="0>0|5" />
        <i3dMapping id="teleportNode" node="0>1" />
    </i3dMappings>
</placeable>
