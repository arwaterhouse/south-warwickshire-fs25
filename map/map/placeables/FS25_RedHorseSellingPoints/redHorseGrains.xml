<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="sellingStation" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_redHorseGrains</name>
        <image>$data/placeables/shared/sellingStationGeneric/store_sellingStationGeneric.dds</image>
        <price>1</price>
        <canBeSold>false</canBeSold>
        <showInStore>false</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <dailyUpkeep>0</dailyUpkeep>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>sellingPoints</category>
        <brush>
            <type>placeable</type>
            <category>production</category>
            <tab>sellingPoints</tab>
        </brush>
        
        <vertexBufferMemoryUsage>222464</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>33792</indexBufferMemoryUsage>
        <textureMemoryUsage>2162688</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>map/placeables/sellingStationGeneric/sellingStationGeneric.i3d</filename>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" />

    <clearAreas></clearAreas>

    <leveling></leveling>

    <indoorAreas></indoorAreas>

    <ai>
        <updateAreas/>
        <splines>
            <spline node="aiSpline" />
        </splines>
    </ai>

    <hotspots>
        <hotspot type="UNLOADING" linkNode="unloadMarkerTrailer" teleportNode="unloadMarkerTrailer" />
    </hotspots>

    

    <triggerMarkers>
        <triggerMarker node="unloadMarkerTrailer" filename="$data/shared/assets/marker/markerIconUnload.i3d"/>
    </triggerMarkers>

    <sellingStation appearsOnStats="true" supportsExtension="false" litersForFullPriceDrop="200000" fullPriceRecoverHours="48">
        <unloadTrigger exactFillRootNode="unloadNodeTrailer" fillTypeCategories="SELLINGSTATION_FIELDFRUITS" priceScale="1" aiNode="unloadNodeAI"/>
        <palletTrigger triggerNode="palletTrigger" fillTypeCategories="SELLINGSTATION_FIELDFRUITS" priceScale="1" />
        <baleTrigger triggerNode="baleTrigger" deleteLitersPerSecond="10000" fillTypeCategories="SELLINGSTATION_FIELDFRUITS" priceScale="1" />
    </sellingStation>

    <i3dMappings>
        <i3dMapping id="unloadStationTrailer" node="0>0" />
        <i3dMapping id="unloadNodeTrailer" node="0>0|0" />
        <i3dMapping id="unloadMarkerTrailer" node="0>0|1" />
        <i3dMapping id="unloadNodeAI" node="0>0|2" />
        <i3dMapping id="palletTrigger" node="0>0|3" />
        <i3dMapping id="baleTrigger" node="0>0|4" />
        <i3dMapping id="aiSpline" node="0>0|5" />
        <i3dMapping id="teleportNode" node="0>1" />
    </i3dMappings>
</placeable>
