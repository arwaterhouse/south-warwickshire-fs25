        <i3dMapping id="lightSwitchNode01" node="0>11|1|7" />
        <i3dMapping id="lightSwitchNode02" node="0>11|1|8" />
        <i3dMapping id="triggerLight01" node="0>11|2" />
        <i3dMapping id="triggerLight02" node="0>11|3" />
        <i3dMapping id="infoTrigger" node="0>12" />
