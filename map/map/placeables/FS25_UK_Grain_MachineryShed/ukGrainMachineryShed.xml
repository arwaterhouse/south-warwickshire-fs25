<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="Shed" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>            
           <en>UK Grain Machinery Shed</en> 
        </name>
		<functions>
            <function>$l10n_function_garageBulk</function>
        </functions>
        <image>placeables/FS25_UK_Grain_MachineryShed/store_ukGrainMachineryShed.dds</image>
        <price>56000</price>
        <dailyUpkeep>25</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>Lizard</brand>
        <species>PLACEABLE</species>
        <canBeSold>true</canBeSold>
        <showInStore>true</showInStore>
        <category>sheds</category>
        <brush>
            <type>placeable</type>
            <category>buildings</category>
            <tab>sheds</tab>
        </brush>
    </storeData>

    <base>
        <filename>placeables/FS25_UK_Grain_MachineryShed/FS25_GrainMachineShed.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <boughtWithFarmland>true</boughtWithFarmland>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" placementPositionSnapSize="0" placementRotationSnapAngle="0">
        <testAreas>
            <testArea startNode="testAreaStart" endNode="testAreaEnd" />
        </testAreas>

        <sounds>
            <place template="smallImp" />
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearAreaStart01" widthNode="clearAreaWidth01" heightNode="clearAreaHeight01"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="10" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="levelAreaStart01" widthNode="levelAreaWidth01" heightNode="levelAreaHeight01"/>
        </levelAreas>
		
		<paintAreas>
			<paintArea startNode="paintAreaStart01" widthNode="paintAreaWidth01" heightNode="paintAreaHeight01" groundType="concrete"/>
        </paintAreas>
    </leveling>

    <indoorAreas>
        <indoorArea startNode="indoorAreaStart01" widthNode="indoorAreaWidth01" heightNode="indoorAreaHeight01"/>
    </indoorAreas>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart" endNode="tipOcclusionUpdateAreaEnd" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart" endNode="tipOcclusionUpdateAreaEnd" />
        </updateAreas>
    </ai>
	
	<incomePerHour>0</incomePerHour>
	
	<windTurbine optimalWindSpeed="5">
        <animationNodes>
            <animationNode node="0>1|3|1|1|0" rotSpeed="1060" rotAxis="3" />
			<animationNode node="0>1|3|1|1|1" rotSpeed="1060" rotAxis="3" />
        </animationNodes>
        <sounds>
        </sounds>
    </windTurbine>
	
	<animatedObjects>
        <animatedObject saveId="rollupDoor">
            <animation duration="3">
                <part node="segment01">
					<Keyframe time="0" translation="0 1.93383098 0.0310297" scale="1 1 1"/>
					<Keyframe time="0.2" translation="0 1.93383098 0.0310297" scale="1 0 1"/>
				</part>
				<part node="segment02">
					<Keyframe time="0" translation="0 0.98323107 0.0310297" scale="1 1 1"/>
					<Keyframe time="0.2" translation="0 1.93383098 0.0310297" scale="1 1 1"/>
					<Keyframe time="0.4" translation="0 1.93383098 0.0310297" scale="1 0 1"/>
				</part>
				<part node="segment03">
					<Keyframe time="0" translation="0 0.03219104 0.0310297" scale="1 1 1"/>
					<Keyframe time="0.4" translation="0 1.93383098 0.0310297" scale="1 1 1"/>
					<Keyframe time="0.6" translation="0 1.93383098 0.0310297" scale="1 0 1"/>
				</part>
				<part node="segment04">
					<Keyframe time="0" translation="0 -0.91867888 0.0310297" scale="1 1 1"/>
					<Keyframe time="0.6" translation="0 1.93383098 0.0310297" scale="1 1 1"/>
					<Keyframe time="0.8" translation="0 1.93383098 0.0310297" scale="1 0 1"/>
				</part>
				<part node="segment05">
					<Keyframe time="0" translation="0 -1.86914492 0.0310297" scale="1 1 1"/>
					<Keyframe time=".8" translation="0 1.93383098 0.0310297" scale="1 1 1"/>
					<Keyframe time="1.0" translation="0 1.93383098 0.0310297" scale="1 0 1"/>
				</part>
            </animation>
            <controls triggerNode="doorTrigger" posAction="ACTIVATE_HANDTOOL" posText="action_openGate" negText="action_closeGate" />
            <sounds>
                <moving linkNode="doorSound" template="rollingGarageDoor" />
                <posEnd linkNode="doorSound" template="slidingGateMetalOpen" />
                <negEnd linkNode="doorSound" template="slidingGateMetalClose" />
            </sounds>
        </animatedObject>
		
		<animatedObject saveId="insideLights">
            <animation duration="1">
                <part node="light01">
                    <keyFrame time="0" visibility="false" />
                    <keyFrame time="0.1" visibility="true" />
                </part>
                <part node="light02">
                    <keyFrame time="0" visibility="false" />
                    <keyFrame time="0.2" visibility="true" />
                </part>
				<part node="light03">
                    <keyFrame time="0" visibility="false" />
                    <keyFrame time="0.3" visibility="true" />
                </part>
		  </animation>    
                 <controls triggerNode="lightsTrigger" posAction="ACTIVATE_HANDTOOL" posText="Turn on Lights" negText="Turn off Lights" />
				 <sounds>
					<moving linknode="light01" template="lizardFloodLight" />
					<posEnd linknode="light02" template="lizardFloodLight" />
					<negEnd linknode="light03" template="lizardFloodLight" />
				 </sounds>
        </animatedObject>
		
		<animatedObject saveId="Fans" >
			<animation>
				<part node="0>1|3|1|0"> <!-- Static Fans-->
					<keyFrame time="0.0" visibility="true" />
					<keyFrame time="0.01" visibility="false" />
				</part>
				<part node="0>1|3|1|1"> <!-- Rotate Fans -->
					<keyFrame time="0.0" visibility="false" />
					<keyFrame time="0.01" visibility="true" />
				</part>
				<part node="0>1|3|1|2"> 
                    <keyFrame time="0.0" visibility="false" />
                    <keyFrame time="0.01" visibility="true" />
                </part>
			</animation>
            <controls posAction="ACTIVATE_HANDTOOL" triggerNode="0>1|3|1|3" posText="Fans ON" negText="Fans OFF" />
        </animatedObject>
	</animatedObjects>
	
    <i3dMappings>
        
		<!-- areas -->
		<i3dMapping id="clearAreaStart01" node="0>0|0|0" />
        <i3dMapping id="clearAreaWidth01" node="0>0|0|0|0" />
        <i3dMapping id="clearAreaHeight01" node="0>0|0|0|1" />
        <i3dMapping id="levelAreaStart01" node="0>0|1|0" />
        <i3dMapping id="levelAreaWidth01" node="0>0|1|0|0" />
        <i3dMapping id="levelAreaHeight01" node="0>0|1|0|1" />
		<i3dMapping id="testAreaStart" node="0>0|2|0" />
        <i3dMapping id="testAreaEnd" node="0>0|2|0|0" />
        <i3dMapping id="indoorAreaStart01" node="0>0|3|0" />
        <i3dMapping id="indoorAreaWidth01" node="0>0|3|0|0" />
        <i3dMapping id="indoorAreaHeight01" node="0>0|3|0|1" />
        <i3dMapping id="tipOcclusionUpdateAreaStart" node="0>0|4|0" />
        <i3dMapping id="tipOcclusionUpdateAreaEnd" node="0>0|4|0|0" />
		<i3dMapping id="paintAreaStart01" node="0>0|5|0" />
        <i3dMapping id="paintAreaWidth01" node="0>0|5|0|0" />
        <i3dMapping id="paintAreaHeight01" node="0>0|5|0|1" />
		
		<!-- roll-up door -->
		<i3dMapping id="segment01" node="0>4|1" />
		<i3dMapping id="segment02" node="0>4|2" />
		<i3dMapping id="segment03" node="0>4|3" />
		<i3dMapping id="segment04" node="0>4|4" />
		<i3dMapping id="segment05" node="0>4|5" />
		<i3dMapping id="doorTrigger" node="0>4|6" />
		<i3dMapping id="doorSound" node="0>4|7" />
		
		<!-- lights -->
		<i3dMapping id="light01" node="0>3|0|0|1" />
		<i3dMapping id="light02" node="0>3|0|1|1" />
		<i3dMapping id="light03" node="0>3|0|2|1" />
		<i3dMapping id="lightsTrigger" node="0>3|0|3" />
		<i3dMapping id="lightsSound" node="0>3|0|4" />
		
    </i3dMappings>
</placeable>
