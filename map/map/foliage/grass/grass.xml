<?xml version="1.0" encoding="utf-8"?>
<foliageType xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../shared/xml/schema/foliageType.xsd">
    <!-- grass

    0 1 2 3

    1 0 0 0 - invisible
    0 1 0 0 - green small
    1 1 0 0 - green middle
    0 0 1 0 - harvest ready
    1 0 1 0 - cut
    0 1 1 0 - cut 2

    -->
    <foliageLayer densityMapChannelOffset="0" numDensityMapChannels="4" numBlocksPerUnit="6.0" shapeSource="grass.i3d" alignsToSun="false">
        <foliageStateDefaults distanceMapLayer="1" width="1.2" height="1.2" widthVariance="0.2" heightVariance="0.7" horizontalPositionVariance="0.5"/>
        <!-- default LOD distances etc -->
        <foliageLodDefaults lod="0" viewDistance="20" blendOutDistance="2" atlasSize="1" atlasOffset="1 0" texCoords="0 0 1 1"/>
        <foliageLodDefaults lod="1" viewDistance="80" blendOutDistance="2" atlasSize="1" atlasOffset="1 0" texCoords="0 0 1 1"/>
        <!-- 1 0 0 0 - invisible -->
        <foliageState name="invisible" isGrowing="true" />
        <!-- 0 1 0 0 - green small -->
        <foliageState name="greenSmall" numBlocksPerUnit="4.5" width="1.3" heightVariance="0.2" horizontalPositionVariance="0.3" distanceMap="distance/foliage_grass_distance2_diffuse.png" isHarvestReady="true" isGrowing="true" regrowthStart="true" groundType="GRASS" groundTypeMask="GRASS GRASS_CUT SOWN DIRECT_SOWN ROLLER_LINES" isDestructedByWheel="true" isDestructedByDisaster="true">
            <foliageShape probability="100">
                <foliageLod blockShape="0>0|0"/>
                <foliageLod blockShape="0>1|0"/>
            </foliageShape>
			
					<!-- DANDELIONS -->	
			<!-- <foliageShape probability="0.005" >
                <foliageLod blockShape="1>0|0"/>
                <foliageLod blockShape="1>0|1"/>
				<foliageLod blockShape="1>1|0"/>
                <foliageLod blockShape="1>1|1"/>
            </foliageShape> -->
			
		<!-- DAISY -->	
			<foliageShape probability="2" >
                <foliageLod blockShape="2>0|1"/>
				<foliageLod blockShape="2>1|1"/>
            </foliageShape>
        </foliageState>
        <!-- 1 1 0 0 - green middle -->
        <foliageState name="greenMiddle" numBlocksPerUnit="5" width="1.2" height="1" distanceMap="distance/foliage_grass_distance3_diffuse.png" isGrowing="true" isHarvestReady="true" yieldScale="0.8" isDestructibleByWheel="true" isDestructibleByDisaster="true" fieldCourseLineHeight="0.3">
            <foliageShape probability="100">
                <foliageLod blockShape="0>0|1"/>
                <foliageLod blockShape="0>1|1"/>
            </foliageShape>
			
			
		<!-- DANDELIONS -->	
			<foliageShape probability="0.3" >
                <foliageLod blockShape="1>0|0"/>
                <foliageLod blockShape="1>0|1"/>
				<foliageLod blockShape="1>1|0"/>
                <foliageLod blockShape="1>1|1"/>
				<!-- <foliageLod blockShape="1>1|2"/> -->
            </foliageShape>
			
		<!-- DAISY -->	
			<foliageShape probability="1" >
                <foliageLod blockShape="2>0|0"/>
				<foliageLod blockShape="2>1|0"/>
            </foliageShape>
			
		<!-- ORANGEDAISY -->	
			<foliageShape probability="0.01" >
                <foliageLod blockShape="3>0|0"/>
				<foliageLod blockShape="3>1|0"/>
            </foliageShape>
			
        </foliageState>
        <!-- 0 0 1 0 - green big (harvest ready) -->
        <foliageState name="harvestReady" numBlocksPerUnit="4" width="1.2" height="1.3" distanceMap="distance/foliage_grass_distance4_diffuse.png" isGrowing="true" isHarvestReady="true" yieldScale="1.2" isDestructibleByWheel="true" isDestructibleByDisaster="true"  fieldCourseLineHeight="0.5">
            <foliageShape probability="100">
                <foliageLod blockShape="0>0|2"/>
                <foliageLod blockShape="0>1|2"/>
            </foliageShape>
			
			<!-- DANDELIONS -->	
			<foliageShape probability="4">
                <foliageLod blockShape="1>0|0"/>
                <foliageLod blockShape="1>0|1"/>
				<foliageLod blockShape="1>1|0"/>
                <foliageLod blockShape="1>1|1"/>
				<!-- <foliageLod blockShape="1>1|2"/> -->
            </foliageShape>
			
			<!-- DAISY -->	
<!-- 			<foliageShape probability="1" >
                <foliageLod blockShape="2>0|0"/>
				<foliageLod blockShape="2>1|0"/>
            </foliageShape> -->
			
			<!-- ORANGEDAISY -->	
			<foliageShape probability="1.2" >
                <foliageLod blockShape="3>0|0"/>
				<foliageLod blockShape="3>1|0"/>
            </foliageShape>
			
			<!-- FIELDGRASS -->	
			<foliageShape probability="8" >
                <foliageLod blockShape="4>0"/>
				<foliageLod blockShape="4>1"/>
            </foliageShape>
			
        </foliageState>
        <!-- 1 0 1 0 - cut -->
        <foliageState name="cut" numBlocksPerUnit="3" heightVariance="0.3" distanceMap="distance/foliage_grass_distance5_diffuse.png" isCut="true" isDestructibleByWheel="false" isDestructibleByDisaster="false" isMulched="true">
            <foliageShape>
                <foliageLod blockShape="0>0|3"/>
                <foliageLod blockShape="0>1|3"/>
            </foliageShape>
        </foliageState>
        <!-- 0 1 1 0 - cut rolled -->
        <foliageState name="cutRolled" numBlocksPerUnit="2.5" distanceMap="distance/foliage_grass_distance5_diffuse.png" isRolledCut="true">
            <foliageShape>
                <foliageLod blockShape="0>0|4"/>
                <foliageLod blockShape="0>1|4"/>
            </foliageShape>
        </foliageState>
		<!-- 1 1 1 1 - tire tracks (harvested) -->
<!-- 		<foliageState name="tireTracks" height="0.2" width="1.5" distanceMap="distance/foliage_grass_distance5_diffuse.png" isDestructedByWheel="false" isDestructedByDisaster="false" isCut="false" isMulched="true">
            <foliageShape>
                <foliageLod blockShape="0>0|3"/>
                <foliageLod blockShape="0>1|3"/>
            </foliageShape>
        </foliageState> -->
    </foliageLayer>

    <fruitType name="grass" shownOnMap="true" useForFieldMissions="false">
        <mapColors default="0.0423 0.1221 0.0252 1" colorBlind="1.0000 0.9473 0.0369 1"/>
        <harvest litersPerSqm="4.37" groundType="GRASS_CUT"/>
        <windrow fillType="grass_windrow" />
        <growth resetsSpray="true" growthRequiresLime="false"/>
        <soil lowDensityRequired="false" increasesDensity="false" consumesLime="false" startSprayLevel="1"/>
        <seeding directionSnapAngle="0" litersPerSqm="0.012" isAvailable="true" plantsWeed="false"/>
        <cultivation isAllowed="true"/>
    </fruitType>

    <growth>
        <seasonal initialState="greenMiddle">
            <period name="EARLY_SPRING" plantingAllowed="true">
                <update startState="invisible" endState="greenSmall" />
                <update startState="greenMiddle" endState="harvestReady" />
                <update startState="cut" endState="greenSmall" />
                <update startState="cutRolled" endState="greenSmall" />
            </period>
            <period name="MID_SPRING" plantingAllowed="true">
                <update startState="invisible" endState="greenSmall" />
                <update startState="greenSmall" endState="greenMiddle" />
                <update startState="greenMiddle" endState="harvestReady" />
                <update startState="cut" endState="greenSmall" />
                <update startState="cutRolled" endState="greenSmall" />
            </period>
            <period name="LATE_SPRING" plantingAllowed="true">
                <update startState="invisible" endState="greenSmall" />
                <update startState="greenSmall" endState="greenMiddle" />
                <update startState="greenMiddle" endState="harvestReady" />
                <update startState="cut" endState="greenSmall" />
                <update startState="cutRolled" endState="greenSmall" />
            </period>
            <period name="EARLY_SUMMER" plantingAllowed="true">
                <update startState="invisible" endState="greenSmall" />
                <update startState="greenSmall" endState="greenMiddle" />
                <update startState="greenMiddle" endState="harvestReady" />
                <update startState="cut" endState="greenSmall" />
                <update startState="cutRolled" endState="greenSmall" />
            </period>
            <period name="MID_SUMMER" plantingAllowed="true">
                <update startState="invisible" endState="greenSmall" />
                <update startState="greenSmall" endState="greenMiddle" />
                <update startState="greenMiddle" endState="harvestReady" />
                <update startState="cut" endState="greenSmall" />
                <update startState="cutRolled" endState="greenSmall" />
            </period>
            <period name="LATE_SUMMER" plantingAllowed="true">
                <update startState="invisible" endState="greenSmall" />
                <update startState="greenSmall" endState="greenMiddle" />
                <update startState="greenMiddle" endState="harvestReady" />
                <update startState="cut" endState="greenSmall" />
                <update startState="cutRolled" endState="greenSmall" />
            </period>
            <period name="EARLY_AUTUMN" plantingAllowed="true">
                <update startState="invisible" endState="greenSmall" />
                <update startState="greenSmall" endState="greenMiddle" />
                <update startState="greenMiddle" endState="harvestReady" />
                <update startState="cut" endState="greenSmall" />
                <update startState="cutRolled" endState="greenSmall" />
            </period>
            <period name="MID_AUTUMN" plantingAllowed="true">
                <update startState="invisible" endState="greenSmall" />
                <update startState="greenSmall" endState="greenMiddle" />
                <update startState="greenMiddle" endState="harvestReady" />
                <update startState="cut" endState="greenSmall" />
                <update startState="cutRolled" endState="greenSmall" />
            </period>
            <period name="LATE_AUTUMN" plantingAllowed="true">
                <update startState="invisible" endState="greenSmall" />
                <update startState="harvestReady" endState="greenMiddle" /> <!-- knock back due to winter -->
            </period>
            <period name="EARLY_WINTER" />
            <period name="MID_WINTER" />
            <period name="LATE_WINTER">
                <update startState="greenSmall" endState="greenMiddle" />
            </period>
        </seasonal>
    </growth>
</foliageType>
