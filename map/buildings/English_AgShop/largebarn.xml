            </animation>
            <controls triggerNode="rollingDoor3Trigger" posAction="ACTIVATE_HANDTOOL" posText="action_openGate" negText="action_closeGate" />
            <sounds>
                <moving linkNode="rollingDoor3Base" template="rollingGarageDoor" />
                <posEnd linkNode="rollingDoor3Base" template="slidingGateMetalOpen" />
                <negEnd linkNode="rollingDoor3Base" template="slidingGateMetalClose" />
            </sounds>
        </animatedObject>
		
		<animatedObject saveId="door4" >
            <animation duration="1.5">
                <part node="door4">
                    <keyFrame time="0.0" rotation="0 0 0"/>
                    <keyFrame time="1.0" rotation="0 -120 0"/>
                </part>
            </animation>
            <controls triggerNode="door4Trigger" posAction="ACTIVATE_HANDTOOL" posText="action_openDoor" negText="action_closeDoor" />
            <sounds>
                <moving linkNode="door4Base" template="metalDoorsLoop" />
                <posEnd linkNode="door4Base" template="metalDoorsOpen" />
                <negEnd linkNode="door4Base" template="metalDoorsClose" />
            </sounds>
        </animatedObject>
	
			<animatedObject saveId="door5" >
            <animation duration="1.5">
                <part node="door5">
                    <keyFrame time="0.0" rotation="0 0 0"/>
                    <keyFrame time="1.0" rotation="0 -120 0"/>
                </part>
            </animation>
            <controls triggerNode="door5Trigger" posAction="ACTIVATE_HANDTOOL" posText="action_openDoor" negText="action_closeDoor" />
            <sounds>
                <moving linkNode="door5Base" template="metalDoorsLoop" />
                <posEnd linkNode="door5Base" template="metalDoorsOpen" />
                <negEnd linkNode="door5Base" template="metalDoorsClose" />
            </sounds>
        </animatedObject>
	</animatedObjects>	
	
    <triggerMarkers>
        <triggerMarker node="markerWrench" filename="$data/shared/assets/marker/markerIcons.xml" id="WRENCH" />
    </triggerMarkers>

    <!-- Removed hotspot to avoid duplicate shop icon; map icon handled via placeables.xml -->

    <workshop>
        <sellingPoint playerTriggerNode="playerTrigger" iconNode="markerWrench" sellTriggerNode="vehicleTrigger" ownWorkshop="false" mobileWorkshop="false" />
    </workshop>
	
